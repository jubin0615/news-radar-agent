# ============================================================
# News Radar Agent — Docker Compose 환경 변수
# 이 파일을 복사해서 .env 로 이름을 바꾸고 값을 채워주세요.
# cp .env.example .env
# ============================================================

# OpenAI API Key
OPENAI_API_KEY=sk-proj-your-key-here

# PostgreSQL (docker-compose db 서비스)
DB_NAME=newsradar
DB_USERNAME=newsradar
DB_PASSWORD=your-db-password

# JWT 시크릿 (최소 32바이트 이상)
JWT_SECRET=your-jwt-secret-at-least-32-bytes-long
JWT_EXPIRATION_MS=86400000

# CORS — 프론트엔드 배포 도메인 (Vercel 등)
FRONTEND_URL=http://localhost:3000
